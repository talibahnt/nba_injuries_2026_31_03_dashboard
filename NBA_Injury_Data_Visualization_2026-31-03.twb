      <aliases enabled='yes' />
      <column caption='Out Count' datatype='integer' name='[Calculation_2868722650533613568]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Current Status] = &quot;Out&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Questionable Count' datatype='integer' name='[Calculation_2868722650534649857]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Current Status] = &quot;Questionable&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Available Count' datatype='integer' name='[Calculation_2868722650534813698]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Current Status] = &quot;Available&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Probable Count' datatype='integer' name='[Calculation_2868722650534944771]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Current Status] = &quot;Probable&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Doubtful Count' datatype='integer' name='[Calculation_2868722650535170052]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF [Current Status] = &quot;Doubtful&quot; THEN 1 ELSE 0 END)' />
      </column>
      <column caption='Total Players Listed' datatype='integer' name='[Calculation_2868722650535260165]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([Player Name])' />
      </column>
      <column caption='Donut Hole' datatype='integer' name='[Calculation_886294388352634880]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='0' />
      </column>
      <column caption='79 Out' datatype='string' name='[Calculation_886294388359159818]' role='measure' type='nominal'>
        <calculation class='tableau' formula='STR(COUNTD([Player Name])) + &quot; Players&quot;' />
      </column>
      <column caption='Reason Category' datatype='string' name='[Calculation_912049348734496768]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([Reason],  &quot;Injury/Illness&quot;) THEN &quot;Injury/Illness&quot;&#10;ELSEIF CONTAINS([Reason], &quot;G League&quot;) THEN &quot;G League&quot;&#10;ELSEIF [Reason] = &quot;NOT YET SUBMITTED&quot; OR ISNULL([Reason]) THEN &quot;Not Submitted&quot;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='Center Label' datatype='string' name='[Calculation_960955625988206593]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Total: &quot; + STR(COUNT([Player Name])) + &quot; Players&quot;' />
      </column>
      <column caption='Body Part' datatype='string' name='[Calculation_986147636411969537]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF CONTAINS([Reason], &quot;Knee&quot;) THEN &quot;Knee&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Ankle&quot;) THEN &quot;Ankle&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Foot&quot;) OR CONTAINS([Reason], &quot;Toe&quot;) THEN &quot;Foot/Toe&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Calf&quot;) THEN &quot;Calf&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Hip&quot;) THEN &quot;Hip&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Hamstring&quot;) THEN &quot;Hamstring&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Shoulder&quot;) THEN &quot;Shoulder&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Thumb&quot;) OR CONTAINS([Reason], &quot;Finger&quot;) THEN &quot;Thumb/Finger&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Achilles&quot;) THEN &quot;Achilles&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Back&quot;) OR CONTAINS([Reason], &quot;Lumbar&quot;) THEN &quot;Back&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Wrist&quot;) THEN &quot;Wrist&quot;&#10;ELSEIF CONTAINS([Reason], &quot;Elbow&quot;) THEN &quot;Elbow&quot;&#10;ELSE &quot;Other/Non-Injury&quot;&#10;END' />
      </column>
      <column datatype='string' name='[Current Status]' role='dimension' type='nominal' />
      <column aggregation='Avg' datatype='real' name='[Google Maps  State Latitude]' role='measure' semantic-role='[Geographical].[Latitude]' type='quantitative' />
      <column aggregation='Avg' datatype='real' name='[Google Maps State Longitude]' role='measure' semantic-role='[Geographical].[Longitude]' type='quantitative' />
